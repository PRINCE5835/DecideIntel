# ── Copy to .env and fill in your keys ────────────────────────────────
# NEVER commit .env to version control.

# ── REQUIRED: JWT Secret (application will NOT start without this) ────
# Generate one:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# ── REQUIRED: CORS Origins (application will NOT start without this) ──
# Comma-separated list of allowed origins.
# For Vercel:      https://your-app.vercel.app
# For local dev:   http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ── REQUIRED: Auth credentials (one of the following) ─────────────────
# Option A: Set a strong plain-text password (auto-hashed at startup)
AUTH_PASSWORD=
# Option B: Pre-hash the password and set the hash directly
# AUTH_PASSWORD_HASH=

# ── Gemini / LLM (optional — falls back to rule-based if missing) ────
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Rate Limiting ──────────────────────────────────────────────────────
RATELIMIT_AUTH=5 per minute
RATELIMIT_DEFAULT=100 per minute
RATELIMIT_STORAGE=memory://

# ── Caching ────────────────────────────────────────────────────────────
CACHE_TYPE=SimpleCache
CACHE_DEFAULT_TIMEOUT=120
CACHE_KEY_PREFIX=di_

# ── GPU / RAPIDS (optional) ───────────────────────────────────────────
CUDF_ENABLED=0
CUDA_VISIBLE_DEVICES=0

# ── Flask Server ──────────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=8080
FLASK_DEBUG=0

# ── Pipeline ──────────────────────────────────────────────────────────
BATCH_SIZE=10000
PARQUET_COMPRESSION=snappy

# ── Google Cloud (optional — for production GCS / BigQuery) ───────────
GOOGLE_APPLICATION_CREDENTIALS=
GCS_BUCKET=decision-intel-landing
GCS_PROJECT=decision-intel-prod

# ── Supabase (optional — for Vercel/Netlify frontend auth) ────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Neon Serverless PostgreSQL (optional — for Render backend) ────────
DATABASE_URL=
