# Vite environment variables (used at build time)
# Prefix with VITE_ to expose to client code

# Backend API URL (in production, set this to your Render backend URL)
# e.g. VITE_API_BASE=https://decision-intel-api.onrender.com
# Leave empty for local dev (Vite proxy handles /api -> localhost:8080)
VITE_API_BASE=
